{
  "expo": {
    "name": "KSE Grid",
    "slug": "kse-grid-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ksegrid",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ksegrid.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.ksegrid.mobile"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-async-storage/async-storage",
        {
          "exclude": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
